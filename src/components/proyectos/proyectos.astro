---
import proyectos from "./data.json";
---

<section class="proyectos">
	<div class="proyectos__container">
		<h1 class="proyectos__title">Proyectos Web</h1>
		<div class="proyectos__grid">
			{
				proyectos.map((data) => (
					<article class="proyectos__card">
						<h5 class="proyectos__card-title">{data.name}</h5>

						<div class="proyectos__image-wrapper">
							<img
								class="proyectos__img"
								src={data.img}
								alt={data.name}
							/>
						</div>

						<div class="proyectos__body">
							<div>
								<div class="proyectos__tags">
									{data.tecs.map((item) => (
										<span class="proyectos__badge">
											{item}
										</span>
									))}
								</div>
								<p class="proyectos__text">
									{data.description}
								</p>
							</div>

							<div class="home__actions">
								{data.git !== "default" ? (
									<a
										href={data.git}
										class="__button button--primary"
										target="_blank"
										title="Ver código"
									>
										GIT
										<svg
											xmlns="http://www.w3.org/2000/svg"
											width="30"
											height="30"
											class="barra_navegacion_svg"
											viewBox="0 0 16 16"
										>
											<path d="M15.698 7.287 8.712.302a1.03 1.03 0 0 0-1.457 0l-1.45 1.45 1.84 1.84a1.223 1.223 0 0 1 1.55 1.56l1.773 1.774a1.224 1.224 0 0 1 1.267 2.025 1.226 1.226 0 0 1-2.002-1.334L8.58 5.963v4.353a1.226 1.226 0 1 1-1.008-.036V5.887a1.226 1.226 0 0 1-.666-1.608L5.093 2.465l-4.79 4.79a1.03 1.03 0 0 0 0 1.457l6.986 6.986a1.03 1.03 0 0 0 1.457 0l6.953-6.953a1.03 1.03 0 0 0 0-1.457" />
										</svg>
									</a>
								) : (
									<span />
								)}

								{data.url !== "default" ? (
									<a
										href={data.url}
										class="__button button--secondary"
										target="_blank"
										title="Ver demo"
									>
										PREVIEW
										<svg
											xmlns="http://www.w3.org/2000/svg"
											width="30"
											height="30"
											class="barra_navegacion_svg"
											class="bi bi-chevron-compact-right"
											viewBox="0 0 16 16"
										>
											<path
												fill-rule="evenodd"
												d="M6.776 1.553a.5.5 0 0 1 .671.223l3 6a.5.5 0 0 1 0 .448l-3 6a.5.5 0 1 1-.894-.448L9.44 8 6.553 2.224a.5.5 0 0 1 .223-.671"
											/>
										</svg>
									</a>
								) : (
									<span />
								)}
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
